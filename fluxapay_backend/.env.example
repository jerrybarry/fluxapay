# Server Configuration
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
PAY_CHECKOUT_BASE=http://localhost:3001
PAYMENT_RATE_LIMIT_PER_MINUTE=5
PAYMENT_METADATA_MAX_BYTES=16384
PAYMENT_METADATA_MAX_DEPTH=5
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fluxapay

# JWT
JWT_SECRET=your-secret-key-here

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional)
RESEND_API_KEY=

# SMS OTP (optional)
SMS_PROVIDER=none
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MESSAGEBIRD_API_KEY=
MESSAGEBIRD_ORIGINATOR=
OTP_SMS_MAX_PER_MERCHANT_HOUR=10
OTP_SMS_COST_ALERT_DAILY_THRESHOLD=1000

# Webhook
WEBHOOK_SECRET=your-webhook-secret

# Stellar Configuration
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_BASE_FEE=100
STELLAR_MAX_FEE=2000
STELLAR_FEE_BUMP_MULTIPLIER=2
STELLAR_TX_MAX_RETRIES=3
FUNDER_SECRET_KEY=S...
USDC_ISSUER_PUBLIC_KEY=GBBD47IF6LWK7P7MDEVSCWT73IQIGCEZHR7OMXMBZQ3ZONN2T4U6W23Y
MASTER_VAULT_SECRET_KEY=S...
FUNDER_PUBLIC_KEY=G...
SWEEP_ENABLE_ACCOUNT_MERGE=false
SWEEP_CRON=*/5 * * * *
SWEEP_LOCK_TTL_MS=600000

# KMS Configuration
KMS_PROVIDER=local
KMS_ENCRYPTION_PASSPHRASE=your-encryption-passphrase
KMS_ENCRYPTED_MASTER_SEED=
HD_WALLET_MASTER_SEED=

# AWS KMS (if KMS_PROVIDER=aws)
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1

# Soroban Smart Contracts (optional)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
MERCHANT_REGISTRY_CONTRACT_ID=
PAYMENT_CONTRACT_ID=
ADMIN_SECRET_KEY=

# Settlement Batch
EXCHANGE_PARTNER=mock
YELLOWCARD_API_KEY=
YELLOWCARD_API_URL=
ANCHOR_API_KEY=
ANCHOR_API_URL=
SETTLEMENT_FEE_PERCENT=2
SETTLEMENT_CRON=0 0 * * *
SETTLEMENT_BATCH_LIMIT=500

# Exchange Partner Feature Flags
ENABLE_YELLOWCARD_VALIDATION=false
ENABLE_ANCHOR_VALIDATION=false

# Payment Oracle Configuration
ORACLE_POLLING_INTERVAL_MS=30000
ORACLE_MAX_MISSED_POLLS=5
ORACLE_BATCH_SIZE=50
ORACLE_HORIZON_TIMEOUT_MS=10000
ENABLE_SOROBAN_VERIFICATION=false

# Cron Jobs
DISABLE_CRON=false
BILLING_CRON=0 1 * * *
FUNDER_MONITOR_CRON=*/10 * * * *
PAYMENT_EXPIRY_CRON=*/5 * * * *

# Shutdown
SHUTDOWN_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info

# ─── CORS Configuration ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g., "https://app.fluxapay.com,https://dashboard.fluxapay.com")
# In development, localhost is automatically allowed
# In production, you MUST set this to your actual frontend domains
# CORS_ORIGINS="https://app.fluxapay.com,https://dashboard.fluxapay.com"

# ─── Database Configuration (REQUIRED) ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fluxapay?schema=public"

# Docker Compose DB settings (optional, defaults shown)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fluxapay

# ─── JWT Configuration (REQUIRED) ──────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-here"

# ─── Cloudinary Configuration (optional, required for KYC document uploads) ────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Email Configuration (optional) ────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key_here"

# ─── SMS OTP (optional) ───────────────────────────────────────────────────────
# SMS_PROVIDER: none | mock | twilio | messagebird  (mock for automated tests)
SMS_PROVIDER="none"
OTP_SMS_MAX_PER_MERCHANT_HOUR="10"
OTP_SMS_COST_ALERT_DAILY_THRESHOLD="1000"
# Twilio (when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+15551234567"
# MessageBird (when SMS_PROVIDER=messagebird)
MESSAGEBIRD_API_KEY=""
MESSAGEBIRD_ORIGINATOR="FluxaPay"

# ─── Webhook Configuration (optional) ──────────────────────────────────────────
WEBHOOK_SECRET="your-webhook-secret-here"

# ─── Stellar Configuration (REQUIRED) ──────────────────────────────────────────
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_BASE_FEE="100"
STELLAR_MAX_FEE="2000"
STELLAR_FEE_BUMP_MULTIPLIER="2"
STELLAR_TX_MAX_RETRIES="3"
FUNDER_SECRET_KEY="your-funder-secret-key-here"
USDC_ISSUER_PUBLIC_KEY="GBBD47IF6LWK7P7MDEVSCWT73IQIGCEZHR7OMXMBZQ3ZONN2T4U6W23Y" # Example Testnet Asset Issuer for testing
MASTER_VAULT_SECRET_KEY="your-master-vault-secret-key-here" # Vault account that receives swept USDC
FUNDER_PUBLIC_KEY="your-funder-public-key-here" # Optional: account for accountMerge to reclaim XLM reserve
SWEEP_ENABLE_ACCOUNT_MERGE="false" # Set to true to accountMerge after each sweep when FUNDER_PUBLIC_KEY is set
SWEEP_CRON="*/5 * * * *" # Run sweep every 5 minutes (adjust to */10 * * * * for 10 minute interval)
SWEEP_LOCK_TTL_MS="600000" # DB lease TTL in ms (default: 10 min). Must exceed the cron interval.

# ─── HD Wallet & KMS Configuration (REQUIRED) ─────────────────────────────────

# KMS Provider: "local" (development) or "aws" (production)
KMS_PROVIDER="local"

# Local KMS (Development Only)
# Encryption passphrase for local KMS (change this in production-like environments)
KMS_ENCRYPTION_PASSPHRASE="your-strong-passphrase-here"

# Encrypted master seed (generated by KMS provider)
# To generate: Use the KMS CLI tool or encrypt your seed manually
KMS_ENCRYPTED_MASTER_SEED="your-encrypted-seed-here"

# Legacy: Plain-text master seed (DEPRECATED - for backward compatibility only)
# WARNING: This is insecure! Migrate to KMS_ENCRYPTED_MASTER_SEED
# HD_WALLET_MASTER_SEED="your-plain-master-seed-here"

# AWS KMS (Production)
# Required when KMS_PROVIDER=aws
AWS_KMS_KEY_ID="arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"
AWS_REGION="us-east-1"
# AWS credentials should be provided via IAM roles or environment variables:
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY (not recommended to store in .env)

# ─── Soroban Smart Contracts (optional) ────────────────────────────────────────
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
MERCHANT_REGISTRY_CONTRACT_ID="C..."
PAYMENT_CONTRACT_ID="C..."
ADMIN_SECRET_KEY="S..."

# ─── Settlement Batch Configuration ───────────────────────────────────────────

# Exchange / payout partner: "yellowcard" | "anchor" | "mock" (default: mock)
EXCHANGE_PARTNER="mock"

# Yellow Card (https://yellowcard.io) — required when EXCHANGE_PARTNER=yellowcard
YELLOWCARD_API_KEY="yc_your_api_key_here"
YELLOWCARD_API_URL="https://api.yellowcard.io"

# Anchor (https://anchorusd.com) — required when EXCHANGE_PARTNER=anchor
ANCHOR_API_KEY="anc_your_api_key_here"
ANCHOR_API_URL="https://api.anchorusd.com"

# Settlement fee (percentage charged by FluxaPay, default: 2)
SETTLEMENT_FEE_PERCENT="2"

# Cron expression for settlement batch (UTC). Default: daily at midnight UTC.
# Examples:
#   "0 0 * * *"   → every day at 00:00 UTC (default)
#   "0 0 * * 1"   → every Monday at 00:00 UTC (weekly)
#   "*/5 * * * *" → every 5 minutes (testing only)
SETTLEMENT_CRON="0 0 * * *"

# On-chain payment monitor: how often to poll Stellar for incoming USDC (default: every 2 min).
# Automated pulls for pending payments; merchant-triggered charges use the payment creation API.
PAYMENT_MONITOR_CRON="*/2 * * * *"

# ─── Payment Monitor Worker Configuration ──────────────────────────────────────
# Enable/disable the payment monitor worker process (default: true)
PAYMENT_MONITOR_WORKER_ENABLED="true"

# Payment monitor polling interval in milliseconds (default: 120000 = 2 minutes)
PAYMENT_MONITOR_INTERVAL_MS="120000"

# Worker graceful shutdown timeout in milliseconds (default: 5000 = 5 seconds)
WORKER_GRACEFUL_SHUTDOWN_TIMEOUT_MS="5000"

# ─── Underpayment and Timeout Policy Configuration ───────────────────────
# Accept partial payments below this threshold (default: 0.1 = 10%)
# Set to 0 to require full payment amount
UNDERPAYMENT_ACCEPT_THRESHOLD="0.1"

# Maximum time to wait for partial payments (default: 3600000 = 1 hour)
# After this time, partial payments will be marked as expired
PARTIAL_PAYMENT_TIMEOUT_MS="3600000"

# Time to consider a payment "stale" after last activity (default: 1800000 = 30 minutes)
# Stale payments with no activity will be marked as expired
STALE_PAYMENT_TIMEOUT_MS="1800000"

# Enable automatic overpayment acceptance (default: true)
ACCEPT_OVERPAYMENTS="true"

# Billing cycle: subscription renewals (default: daily at 01:00 UTC).
BILLING_CRON="0 1 * * *"

# Funder monitor: how often to check funder account balance (default: every 10 min).
FUNDER_MONITOR_CRON="*/10 * * * *"

# Max number of Payment rows processed per batch run (prevents OOM on huge datasets)
SETTLEMENT_BATCH_LIMIT="500"

# Set to "true" to disable all cron jobs (useful in test/CI environments)
DISABLE_CRON="false"

# ─── Admin Configuration (optional) ────────────────────────────────────────────
# Internal admin secret for /api/admin/* endpoints (X-Admin-Secret header)
ADMIN_INTERNAL_SECRET="your-strong-internal-secret-here"

# ─── E2E / automation (optional) ─────────────────────────────────────────────
# When set, OTP verification accepts this exact 6-digit code without bcrypt check.
# Must match Playwright E2E_TEST_OTP when running real-mode E2E. Never set in production.
# E2E_ACCEPT_OTP="123456"



# ── OpenTelemetry (issue #324) ─────────────────────────────────────────────
# Set OTEL_ENABLED=true to activate distributed tracing.
# OTEL_ENABLED=true

# Logical service name reported to the collector (default: fluxapay-backend).
# OTEL_SERVICE_NAME=fluxapay-backend

# OTLP HTTP endpoint of your collector — Tempo, Jaeger, or OTel Collector.
# Staging: OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Fraction of traces to sample (0.0–1.0).
# Defaults: 0.1 in production, 1.0 in all other environments.
# OTEL_SAMPLE_RATE=0.1

# Graceful shutdown drain timeout in ms (issue #303, default: 30000).
# SHUTDOWN_TIMEOUT_MS=30000
